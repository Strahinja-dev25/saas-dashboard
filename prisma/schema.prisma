// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  ADMIN       // Owner ili glavni admin firme
  DISPATCHER  // Dispatch-uje ture i upravlja kamionima
  DRIVER      // Samo vidi svoje ture i status
}

enum TruckStatus {
  AVAILABLE
  IN_TRANSIT
  MAINTENANCE
  OUT_OF_SERVICE
}

enum LoadStatus {
  PENDING      // Kreirana, ali još nije dispatchovana
  ASSIGNED     // Dodeljena truck-u
  IN_TRANSIT
  DELIVERED
  CANCELLED
}


model Company {
  id              String    @id @default(cuid())
  name            String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users           User[]
  trucks          Truck[]
  drivers         Driver[]
  loads           Load[]
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  role            UserRole  @default(DISPATCHER)

  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Truck {
  id              String       @id @default(cuid())
  unitNumber      String       @unique // Truck 101
  status          TruckStatus  @default(AVAILABLE)    // IN_TRANSIT, AVAILABLE, MAINTENANCE, OUT_OF_SERVICE
  location        String
  destination     String?             // Finalna destinacija kamiona
  equipmentType   String              // Dry Van, Reefer, Flatbed

  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  driverId        String?
  driver          Driver?     @relation(fields: [driverId], references: [id])
  loads           Load[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Driver {
  id                    String     @id @default(cuid())
  name                  String
  email                 String     @unique
  eldStatus             String     @default("CONNECTED") // CONNECTED, DISCONNECTED

  hosAvailable          Float      @default(11.0)
  lastHosReset          DateTime   @default(now())
  isDriving             Boolean    @default(false)

  companyId             String
  company               Company    @relation(fields: [companyId], references: [id])
  trucks                Truck[]

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model Load {
  id              String      @id @default(cuid())

  origin          String      // Odakle kreće (npr. Chicago, IL)
  destination     String      // Gde istovara (npr. Dallas, TX)

  amount          Float       // Gross Revenue od ture
  miles           Int         // Pređene milje na ovoj turi
  status          LoadStatus  @default(PENDING)

  startedAt       DateTime?
  deliveredAt     DateTime?
  estimatedHours  Float       @default(0)

  truckId         String?
  truck           Truck?      @relation(fields: [truckId], references: [id])
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
