// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Truck {
  id              String     @id @default(cuid())
  unitNumber      String     @unique // Truck 101
  driverName      String
  status          String     // IN_TRANSIT, AVAILABLE, MAINTENANCE, OUT_OF_SERVICE
  location        String     // Chicago, IL
  destination     String?    // Finalna destinacija kamiona
  equipmentType   String     // Dry Van, Reefer, Flatbed
  hosRemaining    String     // Hours of Service, "2h 15m"
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  loads           Load[]
}

model Driver {
  id          String     @id @default(cuid())
  name        String
  email       String     @unique
  eldStatus   String     @default("CONNECTED") // CONNECTED, DISCONNECTED
  createdAt   DateTime   @default(now())
}

model Load {
  id          String     @id @default(cuid())
  amount      Float      // Gross Revenue od ture
  miles       Int        // Pređene milje na ovoj turi
  createdAt   DateTime   @default(now())
  
  truckId     String?
  truck       Truck?     @relation(fields: [truckId], references: [id])
}
